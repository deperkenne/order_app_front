<mvc:View controllerName="comkenneorderapp.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:html="http://www.w3.org/1999/xhtml" >

    <Page id="page" title="{i18n>title}" class="landingPage" >
        
        <BusyIndicator 
            id="loading"
            visible="{view>showLoading}"
        />
    
        <FlexBox 
            id="flexheaderMain"
            gap="1.5rem"
            class="customHeader" 
            visible="{= !${view>showLoading} }"
        
        >

           <FlexBox 
              id="flexheaderLeft"
              direction="Row"
              gap="0.5rem"
           >
            
               <VBox id="logob" class="logoBox" >
                <core:Icon
                    id="iconidb"
                    src="sap-icon://product"
                    tooltip="Logo Shopify"
                    class="LogoIcon"/>
                </VBox>

                <Title id="companynameb"
                text="StockManagement"
                level="H1"
                class="appTitle" />

            
           </FlexBox>

           <FlexBox 
             id="flexheaderMidler"
             direction="Row"
             gap="1.5rem"
           
           >

           <Button 
                id="solutionB"
                text="Solution"
                type="Unstyled"
                press="onSolutionPress"
                class="navButton" />

            <Button 
                id="resourceB"
                text="Resource"
                type="Unstyled"
                press="onResourcePress"
                class="navButton" />
                
            <Button 
                id="entrepriseB"
                text="Entreprise"
                type="Unstyled"
                press="onEntreprisePress"
                class="navButton" />
        
           </FlexBox>

           <FlexBox 
             id="flexheaderRight"
             direction="Row"
             gap="0.5rem"
           
           >

           <Button 
                id="logupid"
                text="SignUp"
                type="Unstyled"
                press="onSolutionPress"
                class="loginButton" />

            <Button 
                id="loginid"
                text="Login"
                type="Unstyled"
                press="onResourcePress"
                class="loginButton" />
                
           
        
           </FlexBox>

        </FlexBox>

        <FlexBox id="bodySection" class="body-section">

            <FlexBox id="bodyTop" class="body-top">
                <VBox id="heroTitles" class="hero-titles">
                    <Title id="mainTitle" text="WAS Steck in dir?" class="main-title"/>
                    <Title id="subTitle" text="Popup Sensation" class="sub-title"/>
                </VBox>

                <VBox id="heroDescription" class="hero-description">
                    <Title id="descriptionText" text="Größer träumen, schneller wachsen, mehr verkaufen auf StockManagement." class="description-text"/>
                </VBox>
            </FlexBox>

            <FlexBox id="bodyBottom" class="body-bottom">
                <HBox id="actionButtons" class="action-buttons">
                    <Button id="contactBtn" text="Contact us" type="Unstyled" class="contact-btn"/>
                    <Button id="showProductBtn" text="Show Product" type="Unstyled" class="show-product-btn"/>
                </HBox>
                
                <HBox id="reasonSection" class="reason-section">
                    <Button id="whyBtn" text="The reason why we develop StockManagement" type="Unstyled" class="why-btn"/>
                </HBox>
            </FlexBox>

        </FlexBox>
        <FlexBox id="pagecontaint" class="landing-content" direction="Column">
            <Button id="navigationId" text="GotoAdmin" press="onNavigateTo" />
        </FlexBox> 
       
 
    </Page>
</mvc:View>