<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.m">
    
    <Dialog id="ProductEditDialog" title="Stock Management" contentWidth="450px">
        <content>
            <f:SimpleForm id="StockForm"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanL="4"
                labelSpanM="4"
                columnsL="1"
                columnsM="1">
                <f:content>
                    <Label text="IDProduct" id="ProductLabel1"/>
                    <Input id="ProductInput1" value="{dialogData>/ProductId}" editable="false" />
                    <Label id="ProductLabel2" text="ProductName" />
                    <Input   id="ProductInput2" value="{dialogData>/Productname}" editable="true" />
                    <Label id="ProductLabel3" text="Currency" />
                    <Input   id="ProductInput3" value="{dialogData>/Currency}" editable="true" />
                    <Label id="ProductLabel4" text="Price" />
                    <Input id="ProductInput4" value="{dialogData>/Price}" editable="true" valueLiveUpdate="true" />
                </f:content>
            </f:SimpleForm>
        </content>

        <beginButton>
            <Button 
                id="onSetQuantityId"
                text="Enregistrer" 
                type="Emphasized" 
                icon="sap-icon://save" 
                press="onUpdateProduct" />
        </beginButton>
        <endButton>
            <Button 
                id="closedId"
                text="Close" 
                press="onCloseDialogEdit" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>