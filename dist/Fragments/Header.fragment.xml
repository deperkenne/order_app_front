<core:FragmentDefinition id="headerfrag" xmlns="sap.m"  xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
      <FlexBox 
    id="header"
    gap="1.5rem"
    class="customHeader"  
>
   <FlexBox 
      id="left"
      direction="Row"
      gap="0.5rem"
   >
       <VBox id="logoheader" class="logoBox" >
        <core:Icon
            id="iconheader"
            src="sap-icon://product"
            tooltip="Logo Shopify"
            class="LogoIcon"/>
        </VBox>

        <Title id="titleheader"
        text="StockManagement"
        level="H1"
        class="appTitle" />
   </FlexBox>

   <FlexBox 
     id="middle"
     direction="Row"
     gap="1.5rem"
   >
       <Button 
            id="solution"
            text="Solution"
            type="Unstyled"
            press="onSolutionPress"
            class="navButton" />

        <Button 
            id="resource"
            text="Resource"
            type="Unstyled"
            press="onResourcePress"
            class="navButton" />
            
        <Button 
            id="entreprise"
            text="Entreprise"
            type="Unstyled"
            press="onEntreprisePress"
            class="navButton" />
   </FlexBox>

   <FlexBox 
     id="right"
     direction="Row"
     gap="0.5rem"
   >
       <Button 
            id="signup"
            text="SignUp"
            type="Unstyled"
            press="onSolutionPress"
            class="loginButton" />

        <Button 
            id="login"
            text="Login"
            type="Unstyled"
            press="onResourcePress"
            class="loginButton" />
        
        <Button
            id="addCartid"
            icon="sap-icon://cart"
            text="{products>/countSelectedProduct}"
            type="Transparent"
            press=".toggleDisplay"
            class="panierToggleBtn" />

   </FlexBox>
</FlexBox>
</core:FragmentDefinition>