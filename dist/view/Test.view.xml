<mvc:View controllerName="comkenneorderapp.controller.Test"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m" xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    height="100%"
    class="testpage">
    
    <Page
        id="productsPage"
        title="Catalogue de Produits"
        showNavButton="false"
        class="sapUiResponsiveContentPadding testpage"
        >
        
        <FlexBox
         id="flexheader"
         direction="Column"
         justifyContent="End"
         width="100%"

        >
            <Button
                id="addCart"
                icon="sap-icon://cart"
                text="Panier ({products>/countSelectedProduct})"
                type="Emphasized"
                press="toggleDisplay"
                
                />
            <FlexBox 
                id="flexboxProductsCard"
                class="addedProductCard"
                direction="Column"
                justifyContent="End"
                columnGap="0.8em"
                visible="false"
                width="500px"
                items="{addedProducts>/addedProducts}"  
            
            >
           
                <items>
                           
                            <HBox  
                                 id="showcard"
                                 justifyContent="SpaceBetween"
                            >
                             
                                <Image
                                        id="imgcard"
                                        src="{addedProducts>imageUrl}"
                                        width="30%"
                                        height="30px"
                                        densityAware="false"
                                        decorative="true"
                                        class="productImage"/>
                                <Title
                                        id="productName"
                                        text="{addedProducts>name}"
                                        level="H3"
                                        class="sapUiTinyMarginBottom"/>
                            
                                <ObjectStatus
                                        id="category"
                                        text="{addedProducts>category}"
                                        state="Information"/>
                                <ObjectStatus
                                        id="inStock"
                                        text="{parts: ['addedProducts>inStock'], formatter: '.formatStock'}"
                                        state="{parts: ['addedProducts>inStock'], formatter: '.getStockState'}"/>
                                <ObjectNumber
                                        id="pricecard"
                                        number="{addedProducts>price}"
                                        unit="{addedProducts>currency}"
                                        emphasized="true"
                                        state="Success"/>
                

                            </HBox>
                </items>
    
            </FlexBox>
        </FlexBox>

        
        
        <subHeader>
            <Toolbar id="toolbar">
                <SearchField
                    id="field"
                    width="50%"
                    placeholder="Rechercher un produit..."
                    value="filters/searchQuery"
                    search=".onSearch"/>
                <ToolbarSpacer id="spaceselect"/>
                <Select
                    id="chooseProduct"
                    width="200px"
                    items="{products>/categories}"
                    selectedKey="{products>/filters/selectedCategory}"
                    change=".onCategorySelect">
                    <core:Item  key="{products>}" text="{products>}" xmlns:core="sap.ui.core" id="pid"/>
                </Select>
                 <ToolbarSpacer id="spacebutton"/>
                <Button  
                   id="addcard"
                   icon="sap-icon://cart"
                   text="Panier"
                   type="Emphasized"
                   press="selectedProducts">

                </Button>
    
            </Toolbar>
        </subHeader>
        
        <content>
            <FlexBox
                id="flex"
                class="pageContent"
                direction="Row"
                wrap="Wrap"
                items="{products>/products}"
                >
                        
                        <items>
                           
                            <VBox class="sapUiSmallMarginBottom itemContent"  id="it1">
                                <!-- Card Container -->
                                    
                                   <VBox  id="it2" class="productCard" >
                              
                                    
                                    <!-- Image Section -->
                                    <Image
                                        id="img"
                                        src="{products>imageUrl}"
                                        width="100%"
                                        height="200px"
                                        densityAware="false"
                                        decorative="true"
                                        class="productImage"/>
                                    
                                    <!-- Content Section -->
                                    <VBox  id="it4" class="sapUiSmallMargin ">
                                        
                                        <!-- Category Badge -->
                                        <HBox  id="hbox" justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
                                            <ObjectStatus
                                                 id="stat"
                                                text="{products>category}"
                                                state="Information"/>
                                            <ObjectStatus
                                                id="stat2"
                                                text="{parts: ['products>inStock'], formatter: '.formatStock'}"
                                                state="{parts: ['products>inStock'], formatter: '.getStockState'}"/>
                                        </HBox>
                                        
                                        <!-- Product Name -->
                                        <Title
                                            id="title"
                                            text="{products>name}"
                                            level="H3"
                                            class="sapUiTinyMarginBottom"/>
                                        
                                        <!-- Description -->
                                        <Text
                                             id="text"
                                            text="{products>description}"
                                            maxLines="2"
                                            class="sapUiTinyMarginBottom"/>
                                        
                                        <!-- Rating -->
                                        <RatingIndicator
                                            id="rating"
                                            value="{products>rating}"
                                            maxValue="5"
                                            enabled="false"
                                            class="sapUiTinyMarginBottom"/>
                                        
                                        <!-- Supplier -->
                                        <Text
                                             id="tex"
                                            text="Fournisseur: {products>supplier}"
                                            class="sapUiTinyMarginBottom"/>
                                        
                                        <!-- Price and Action -->
                                        <HBox
                                             id="h1"
                                            justifyContent="SpaceBetween"
                                            alignItems="Center"
                                            class="sapUiSmallMarginTop">
                                            
                                            <ObjectNumber
                                                id="obj"
                                                number="{products>price}"
                                                unit="{products>currency}"
                                                emphasized="true"
                                                state="Success"/>
                                            
                                            <Button
                                                id="bt"
                                                text="Ajouter"
                                                icon="sap-icon://cart"
                                                type="Emphasized"
                                                press=".onAddToCart"
                                                enabled="{products>inStock}"/>
                                        </HBox>
                                    </VBox>
                                </VBox>
                            </VBox>
                        </items>
            </FlexBox>
             
        </content>
    </Page>
</mvc:View>
