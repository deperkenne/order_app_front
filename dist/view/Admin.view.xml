<mvc:View
    controllerName="comkenneorderapp.controller.Admin"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
     xmlns:core="sap.ui.core">
    
    <Page title="Gestion de Stock - Entrepôt Central" id = "StockId" >
        <content >
            <Table id="idStockTable" 
                   items="{stock>/items}" 
                   class="sapUiSmallMarginTop myCustomTable ">
                <headerToolbar>
                    <OverflowToolbar id="stocckHeader">
                        <Title text="Inventaire des Produits" id="StockTitle" />
                        <ToolbarSpacer id="spaceId" />
                        <SearchField width="30%" search=".onSearch" id="SearchProduitId"/>
                        <Button id="AddProduct" icon="sap-icon://add" text="Ajouter" press=".onCreateStock" type="Emphasized" />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column id="StocKColId" hAlign="Center"><Text text="StockID"  id="Column1Title"/></Column>
                    <Column id="StockColProductID" hAlign="Center" minScreenWidth="Tablet" demandPopin="true"><Text text="ProductId" id="Column2Title"/></Column>
                    <Column id="StockColSkuID" hAlign="Center"><Text id="Column3Title"  text="SkuId" /></Column>
                    <Column id="StockColQuantity" hAlign="Center"><Text id="Column4Title" text="Quantity" /></Column>
                    <Column id="StockColAvailableQuantity" hAlign="Center"><Text id="Column5Title" text="AvailableQuantity" /></Column>
                    <Column id="StockColStatus" hAlign="Center"><Text id="Column7Title" text="Status" /></Column>
                    <Column id="StockColActions" hAlign="Center" width="80px"><Text text="Actions" id="Column8Title" /></Column>
                </columns>
                <items>
                    <ColumnListItem id="StockCell" vAlign="Middle" >
                        <cells >
                            <ObjectIdentifier id="StockCellIdInfo"  text="{stock>StockId}" />
                            <Text id="StockCellProductIdInfo" text="{stock>ProductId}" />
                            <Text id="StockCellSkuInfo" text="{stock>SkuId}" />
                            <Text id="StockCellQtyInfo" text="{stock>Quantity} {stock>Unit}" />
                            <Text id="StockCellAvQtyInfo" text="{stock>AvailableQuantity}" />
                           

                            <ObjectStatus 
                                id="StockCellStatusInfo"
                                text="{/status}" 
                                state="{= ${stock>Quantity} > 10 ? 'Success' : 'Error' }" />
                            <HBox id="StockAction"> 
                                <Button 
                                        id="StockEdit" 
                                        type="Ghost"
                                        icon="sap-icon://edit"
                                        iconFirst="false"
                                        press=".openAuthDialog($event, 'EDIT')"
                                        ariaLabelledBy="Column5Title" />
                                <Button id="DeleteBtn"
                                    icon="sap-icon://delete" 
                                    type="Transparent" 
                                    press=".openAuthDialog($event, 'DELETE')"
                                    ariaLabelledBy="Column8Title" />
                            </HBox>   
                            
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        
    </Page>
</mvc:View>